{
	"name": "grrr-monorepo",
	"private": true,
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo run build",
		"build:vercel": "node scripts/bundle-api.mjs && pnpm --filter web build:vercel",
		"type-check": "turbo run type-check",
		"lint": "turbo run lint",
		"test": "turbo run test",
		"clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules"
	},
	"devDependencies": {
		"@typescript-eslint/eslint-plugin": "7.18.0",
		"@typescript-eslint/parser": "7.18.0",
		"esbuild": "^0.25.0",
		"eslint": "8.57.1",
		"turbo": "latest",
		"typescript": "^5.0.0",
		"vitest": "^1.6.0"
	},
	"packageManager": "pnpm@9.0.0",
	"pnpm": {
		"overrides": {
			"jose": "4.15.9"
		}
	},
	"dependencies": {
		"tsx": "^4.7.0",
		"firebase-admin": "^14.1.0",
		"@google/genai": "^2.10.0"
	}
}